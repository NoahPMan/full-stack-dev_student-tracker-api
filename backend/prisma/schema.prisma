generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/* your models below */
enum HomeworkStatus {
  todo
  in_progress
  done
}

model Homework {
  id        String          @id @default(cuid())
  title     String
  courseId  String
  dueDate   DateTime
  status    HomeworkStatus  @default(todo)
  createdAt DateTime        @default(now())
}