generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum HomeworkStatus {
  todo
  in_progress
  done
}

model Course {
  id          String   @id @default(uuid())
  userId      String

  code        String
  name        String
  credits     Int?
  instructor  String?
  semester    String?
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  homework    Homework[]
  notes       Note[]

  @@unique([userId, code])
  @@index([userId])
  @@map("courses")
}

model Homework {
  id          String         @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  status      HomeworkStatus @default(todo)
  createdAt   DateTime       @default(now())

  userId      String

  courseId    String?
  course      Course?        @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([dueDate])
}

model Note {
  id        String    @id @default(cuid())
  title     String
  body      String
  pinned    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  userId    String

  courseId  String?
  course    Course?   @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([pinned])
}